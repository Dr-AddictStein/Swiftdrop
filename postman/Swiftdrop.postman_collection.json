                "body": { "mode": "raw", "raw": "{\n  \"parcelId\": \"{{parcelId}}\",\n  \"status\": \"OUT_FOR_DELIVERY\",\n  \"remarks\": \"On the way\"\n}" },
                "url": { "raw": "{{baseUrl}}/delivery-events", "host": ["{{baseUrl}}"], "path": ["delivery-events"] }
