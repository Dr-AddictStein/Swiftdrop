            {
              "name": "Get events by parcel",
              "request": {
                "method": "GET",
                "header": [
                  { "key": "x-api-key", "value": "{{apiKey}}" },
                  { "key": "Authorization", "value": "Bearer {{agentToken}}" }
                ],
                "url": { "raw": "{{baseUrl}}/delivery-events/{{parcelId}}", "host": ["{{baseUrl}}"], "path": ["delivery-events", "{{parcelId}}"] }
              }
            }
          ]
        },
        {
          "name": "Profile & Lifecycle",
          "item": [
            {
              "name": "Report my incident",
              "request": {
                "method": "POST",
                "header": [
                  { "key": "Content-Type", "value": "application/json" },
                  { "key": "x-api-key", "value": "{{apiKey}}" },
                  { "key": "Authorization", "value": "Bearer {{agentToken}}" }
                ],
                "body": { "mode": "raw", "raw": "{\n  \"reason\": \"Feeling unwell\"\n}" },
                "url": { "raw": "{{baseUrl}}/agents/me/report-incident", "host": ["{{baseUrl}}"], "path": ["agents", "me", "report-incident"] }
              }
            },
            {
              "name": "Switch company",
              "request": {
                "method": "POST",
                "header": [
                  { "key": "Content-Type", "value": "application/json" },
                  { "key": "x-api-key", "value": "{{apiKey}}" },
                  { "key": "Authorization", "value": "Bearer {{agentToken}}" }
                ],
                "body": { "mode": "raw", "raw": "{\n  \"joinCode\": \"{{targetJoinCode}}\"\n}" },
                "url": { "raw": "{{baseUrl}}/agents/me/switch-company", "host": ["{{baseUrl}}"], "path": ["agents", "me", "switch-company"] }
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Common (Any authenticated)",
      "description": "Endpoints usable by any logged-in user. Data is still scoped by the service to the caller's company. Default token here is {{adminToken}} - swap for {{agentToken}} or {{superAdminToken}} as needed.",
      "item": [
        {
          "name": "List companies (join codes)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const list = pm.response.json();",
                  "  if (list.length) { pm.collectionVariables.set('targetJoinCode', list[list.length - 1].joinCode); }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "x-api-key", "value": "{{apiKey}}" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/companies", "host": ["{{baseUrl}}"], "path": ["companies"] }
          }
        },
        {
          "name": "Realtime stream (SSE)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "text/event-stream" },
              { "key": "x-api-key", "value": "{{apiKey}}" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/realtime/stream", "host": ["{{baseUrl}}"], "path": ["realtime", "stream"] }
          }
        }
      ]
    }
  ]
}
