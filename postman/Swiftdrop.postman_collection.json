{
  "info": {
    "name": "Swiftdrop Delivery API",
    "_postman_id": "b1e7a1c2-4d3f-4b6a-9f00-swiftdrop0001",
    "description": "Multi-tenant last-mile delivery API.\n\nRequests are grouped by ROLE (Authentication, Super Admin, Admin, Delivery Agent, Common) and then by OPERATION.\n\nHow to use:\n1. Set `baseUrl` and `apiKey` (see collection variables, or import the provided environment).\n2. Run the login requests in **Authentication** first. Their test scripts automatically store `superAdminToken`, `adminToken` and `agentToken`.\n3. List endpoints (users, parcels, notifications, companies) capture the first id/join code into variables so you can run the rest without editing anything.\n\nEvery protected request sends two headers: `x-api-key` and `Authorization: Bearer <token>`.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000", "type": "string" },
    { "key": "apiKey", "value": "dev-api-key", "type": "string" },
    { "key": "superAdminToken", "value": "", "type": "string" },
    { "key": "adminToken", "value": "", "type": "string" },
    { "key": "agentToken", "value": "", "type": "string" },
    { "key": "companyId", "value": "", "type": "string" },
    { "key": "targetJoinCode", "value": "METRO1", "type": "string" },
    { "key": "userId", "value": "", "type": "string" },
    { "key": "agentId", "value": "", "type": "string" },
    { "key": "parcelId", "value": "", "type": "string" },
    { "key": "notificationId", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "Authentication (Public)",
      "description": "Public endpoints. No API key or token required. Run a login here first to populate tokens.",
      "item": [
        {
          "name": "Health check",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/", "host": ["{{baseUrl}}"], "path": [""] }
          }
        },
        {
          "name": "Register company + admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const json = pm.response.json();",
                  "  pm.collectionVariables.set('adminToken', json.accessToken);",
                  "  if (json.user && json.user.companyId) {",
                  "    pm.collectionVariables.set('companyId', json.user.companyId);",
                  "  }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"companyName\": \"Acme Delivery\",\n  \"name\": \"Alice Admin\",\n  \"email\": \"alice@acme.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/register", "host": ["{{baseUrl}}"], "path": ["auth", "register"] }
          }
        },
        {
          "name": "Login - Super Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  pm.collectionVariables.set('superAdminToken', pm.response.json().accessToken);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"superadmin@swiftdrop.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] }
          }
        },
        {
          "name": "Login - Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const json = pm.response.json();",
                  "  pm.collectionVariables.set('adminToken', json.accessToken);",
                  "  if (json.user && json.user.companyId) {",
                  "    pm.collectionVariables.set('companyId', json.user.companyId);",
                  "  }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@swiftdrop.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] }
          }
        },
        {
          "name": "Login - Delivery Agent",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  pm.collectionVariables.set('agentToken', pm.response.json().accessToken);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"agent@swiftdrop.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] }
          }
        }
      ]
    },
